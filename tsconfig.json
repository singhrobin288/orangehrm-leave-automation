{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@pages/*": ["./src/pages/*"],
      "@actions/*": ["./src/actions/*"],
      "@support/*": ["./src/support/*"],
      "@config/*": ["./src/config/*"]
    }
  },
  "include": ["src/**/*", "features/**/*"],
  "exclude": ["node_modules", "dist", "reports"]
}
